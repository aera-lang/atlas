---
type Subsection = { id: string; title: string }
type Section    = { id: string; title: string; subsections?: Subsection[] }

interface Props {
    sections: Section[]
}

const { sections } = Astro.props
---

<nav class="atlas-nav" aria-label="Atlas sections">
    {sections.map(section => (
        <div class="nav-group">
        <a href={`#${section.id}`} class="nav-section" data-id={section.id}>
            {section.title}
        </a>
        {section.subsections && section.subsections.length > 0 && (
            <div class="nav-subsections">
            {section.subsections.map(sub => (
                <a href={`#${sub.id}`} class="nav-sub" data-id={sub.id}>
                {sub.title}
                </a>
            ))}
            </div>
        )}
        </div>
    ))}
</nav>

<style>
    .atlas-nav {
        display: flex;
        flex-direction: column;
        gap: 0.125rem;
        font-size: 0.875rem;
    }

    .nav-group {
        display: flex;
        flex-direction: column;
    }

    .nav-section {
        display: block;
        border-radius: 0.5rem;
        padding: 0.375rem 0.75rem;
        font-weight: 500;
        color: var(--deep);
        text-decoration: none;
        transition: background-color 0.15s, color 0.15s;
    }

    .nav-section:hover        { background: var(--mist); }
    .nav-section.active       { background: var(--accent); color: var(--accent-foreground); }

    .nav-subsections {
        display: flex;
        flex-direction: column;
        gap: 0.125rem;
        margin-top: 0.125rem;
        border-left: 1px solid var(--border);
        padding-left: 0.75rem;
    }

    .nav-sub {
        display: block;
        border-radius: 0.5rem;
        padding: 0.25rem 0.75rem;
        font-size: 0.8125rem;
        color: var(--muted-foreground);
        text-decoration: none;
        transition: color 0.15s;
    }

    .nav-sub:hover  { color: var(--deep); }
    .nav-sub.active { color: var(--primary); font-weight: 500; }
</style>

<script>
    const nav   = document.querySelector('.atlas-nav')!
    const links = Array.from(nav.querySelectorAll<HTMLAnchorElement>('[data-id]'))
    const ids   = links.map(l => l.dataset.id!)

    function setActive(id: string) {
        links.forEach(l => l.classList.toggle('active', l.dataset.id === id))
    }

    setActive(ids[0])

    const observer = new IntersectionObserver(
        (entries) => {
        const visible = entries
            .filter(e => e.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)
        if (visible[0]) setActive(visible[0].target.id)
        },
        { rootMargin: '-80px 0px -70% 0px', threshold: 0 },
    )

    ids.forEach(id => {
        const el = document.getElementById(id)
        if (el) observer.observe(el)
    })
</script>