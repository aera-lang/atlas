---
interface Props {
  kind?: 'note' | 'warning' | 'error'
  title?: string
}

const { kind = 'note', title } = Astro.props

const defaults = {
  note:    { title: 'Note',    icon: `<svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor"><path d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8Zm8-6.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13ZM6.5 7.75A.75.75 0 0 1 7.25 7h1a.75.75 0 0 1 .75.75v2.75h.25a.75.75 0 0 1 0 1.5h-2a.75.75 0 0 1 0-1.5h.25v-2h-.25a.75.75 0 0 1-.75-.75ZM8 6a1 1 0 1 1 0-2 1 1 0 0 1 0 2Z"/></svg>` },
  warning: { title: 'Warning', icon: `<svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor"><path d="M6.457 1.047c.659-1.234 2.427-1.234 3.086 0l6.082 11.378A1.75 1.75 0 0 1 14.082 15H1.918a1.75 1.75 0 0 1-1.543-2.575Zm1.763.707a.25.25 0 0 0-.44 0L1.698 13.132a.25.25 0 0 0 .22.368h12.164a.25.25 0 0 0 .22-.368Zm.53 3.996v2.5a.75.75 0 0 1-1.5 0v-2.5a.75.75 0 0 1 1.5 0ZM9 11a1 1 0 1 1-2 0 1 1 0 0 1 2 0Z"/></svg>` },
  error:   { title: 'Error',   icon: `<svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor"><path d="M2.343 13.657A8 8 0 1 1 13.658 2.343 8 8 0 0 1 2.343 13.657ZM6.03 4.97a.751.751 0 0 0-1.042.018.751.751 0 0 0-.018 1.042L6.94 8 4.97 9.97a.749.749 0 0 0 .326 1.275.749.749 0 0 0 .734-.215L8 9.06l1.97 1.97a.749.749 0 0 0 1.275-.326.749.749 0 0 0-.215-.734L9.06 8l1.97-1.97a.749.749 0 0 0-.326-1.275.749.749 0 0 0-.734.215L8 6.94Z"/></svg>` },
}

const label = title ?? defaults[kind].title
const icon  = defaults[kind].icon
---

<aside class={`callout callout-${kind}`}>
  <p class="callout-header">
    <span class="callout-icon" aria-hidden="true" set:html={icon} />
    <span class="callout-title">{label}</span>
  </p>
  <div class="callout-body">
    <slot />
  </div>
</aside>

<style>
  .callout {
    border-radius: 0.375rem;
    border: 1px solid;
    border-left-width: 4px;
    padding: 0.75rem 1rem;
    font-size: 0.9375rem;
    line-height: 1.65;
  }

  .callout-note {
    background: color-mix(in srgb, var(--blue) 20%, transparent);
    border-color: color-mix(in srgb, var(--blue) 60%, transparent);
    border-left-color: color-mix(in srgb, var(--blue) 90%, transparent);
    color: var(--deep);
  }

  .callout-warning {
    background: color-mix(in srgb, var(--cream) 40%, transparent);
    border-color: color-mix(in srgb, var(--cream) 70%, transparent);
    border-left-color: color-mix(in srgb, var(--cream) 95%, transparent);
    color: var(--deep);
  }

  .callout-error {
    background: color-mix(in srgb, var(--pink) 30%, transparent);
    border-color: color-mix(in srgb, var(--pink) 60%, transparent);
    border-left-color: color-mix(in srgb, var(--pink) 95%, transparent);
    color: var(--deep);
  }

  .callout-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin: 0 0 0.375rem;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 700;
  }

  .callout-note    .callout-header { color: color-mix(in srgb, var(--blue) 50%, var(--deep)); }
  .callout-warning .callout-header { color: color-mix(in srgb, var(--cream) 50%, var(--deep)); }
  .callout-error   .callout-header { color: color-mix(in srgb, var(--pink) 50%, var(--deep)); }

  .callout-icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .callout-body :global(p) {
    margin: 0;
    color: var(--foreground);
  }

  .callout-body :global(p + p) {
    margin-top: 0.375rem;
  }

  .callout-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: color-mix(in srgb, var(--deep) 8%, transparent);
    padding: 0.1em 0.3em;
    border-radius: 0.25rem;
  }
</style>