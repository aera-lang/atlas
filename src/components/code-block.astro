---
interface Props {
  code: string
  label?: string
  class?: string
}

const { code, label, class: className } = Astro.props

const KEYWORDS = new Set([
    'fn', 'let', 'mut', 'const', 'pub', 'if', 'else',
    'for', 'while', 'loop', 'match', 'break',
    'true', 'false',
    'return', 'unit', 'struct', 'variant', 'in', 'as',
])

type TokenKind = 'keyword' | 'string' | 'number' | 'call' | 'comment' | 'punct' | 'plain'
type Token = { text: string; kind: TokenKind }

function tokenize(source: string): Token[][] {
    const lines = source.replace(/\n$/, '').split('\n')
    const result: Token[][] = []
    let inBlockComment = false

    for (const line of lines) {
        const tokens: Token[] = []
        let pos = 0

        if (inBlockComment) { // scan for closing '#>'
            const closeIdx = line.indexOf('#>')
            if (closeIdx === -1) {
                result.push([{ text: line, kind: 'comment' }])
                continue
            }
            tokens.push({ text: line.slice(0, closeIdx + 2), kind: 'comment' })
            inBlockComment = false
            pos = closeIdx + 2
        }

        while (pos < line.length) {
            if (line[pos] === '<' && line[pos + 1] === '#') { // open block comment
                const closeIdx = line.indexOf('#>', pos + 2)
                if (closeIdx === -1) {
                    tokens.push({ text: line.slice(pos), kind: 'comment' })
                    inBlockComment = true
                    pos = line.length
                } 
                else {
                    tokens.push({ text: line.slice(pos, closeIdx + 2), kind: 'comment' })
                    pos = closeIdx + 2
                }
                continue
            }

            if (line[pos] === '#') {
                tokens.push({ text: line.slice(pos), kind: 'comment' })
                break
            }

            const quote = line[pos]
            if (quote === '"' || quote === "'") {
                let end = pos + 1
                while (end < line.length && line[end] !== quote) end++
                tokens.push({ text: line.slice(pos, end + 1), kind: 'string' })
                pos = end + 1
                continue
            }

            if (/[0-9]/.test(line[pos])) {
                let end = pos
                while (end < line.length && /[0-9._]/.test(line[end])) end++
                tokens.push({ text: line.slice(pos, end), kind: 'number' })
                pos = end
                continue
            }

            if (/[A-Za-z_]/.test(line[pos])) {
                let end = pos
                while (end < line.length && /[A-Za-z0-9_]/.test(line[end])) end++
                const word = line.slice(pos, end)
                const isCall = line[end] === '('
                tokens.push({ text: word, kind: KEYWORDS.has(word) ? 'keyword' : isCall ? 'call' : 'plain' })
                pos = end
                continue
            }

            let end = pos
            while (end < line.length && !/[A-Za-z0-9_"'#<]/.test(line[end])) {
                if (line[end] === '<' && line[end + 1] === '#') break // stop if block comment opener found
                end++
            }
            if (end === pos) end++
            tokens.push({ text: line.slice(pos, end), kind: 'punct' })
            pos = end
        }

        result.push(tokens)
    }

    return result
}

const tokenized = tokenize(code)
---

<div class:list={['code-block', className]}>
    {label && (
        <div class="code-header">
        <span class="code-label">{label}</span>
        </div>
    )}
    <pre><code>{tokenized.map(toks => (
        <span class="line">{toks.length === 0
        ? <span> </span>
        : toks.map(t => <span class={`tok-${t.kind}`}>{t.text}</span>)
        }</span>
    ))}</code></pre>
    </div>

    <style>
    .code-block {
        overflow: hidden;
        border-radius: 0.75rem;
        border: 1px solid color-mix(in srgb, var(--accent) 70%, transparent);
        background: var(--mist);
    }

    .code-header {
        display: flex;
        align-items: center;
        gap: 0.375rem;
        border-bottom: 1px solid color-mix(in srgb, var(--accent) 60%, transparent);
        background: color-mix(in srgb, var(--accent) 30%, transparent);
        padding: 0.5rem 1rem;
    }

    .code-label {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--muted-foreground);
    }

    pre {
        margin: 0;
        overflow-x: auto;
        padding: 1rem;
        font-family: var(--font-mono);
        font-size: 0.8125rem;
        line-height: 1.7;
    }

    @media (min-width: 640px) {
        pre { font-size: 0.875rem; }
    }

    .line { display: block; }

    .tok-keyword { color: #a25fb0; font-weight: 500; }
    .tok-string  { color: #3d8a8a; }
    .tok-number  { color: #c47a3d; }
    .tok-call    { color: #5c7cc4; }
    .tok-comment { color: #9a8fb0; font-style: italic; }
    .tok-punct   { color: #7a6e93; }
    .tok-plain   { color: var(--deep); }
</style>