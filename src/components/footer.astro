---
import GitHubLink from "./github-link.astro"
---

<footer class="footer">
    <div class="footer-inner">
        <div class="footer-brand">
        <img src="https://placehold.co/24x24" alt="" width="24" height="24" />
        <span class="footer-name">Aera</span>
        <span class="footer-sep">·</span>
        <span class="footer-tagline">A solo language project.</span>
        </div>

        <nav class="footer-links" aria-label="Footer">
        <a href="/vision">Vision</a>
        <a href="/atlas">Atlas</a>
        <a href="/gallery">Gallery</a>
        <a href="/roadmap">Roadmap</a>
        <GitHubLink href="https://github.com/aera-lang/aera" class="footer-github" width={14} height={14}/>
        </nav>
    </div>
</footer>

<style>
    .footer {
        border-top: 1px solid var(--border);
		background: var(--background);
    }

    .footer-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        max-width: 72rem;
        margin-inline: auto;
        padding: 0.875rem 1.25rem;
    }

    @media (min-width: 640px) {
        .footer-inner { flex-direction: row; }
    }

    .footer-brand {
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .footer-brand img {
        width: 1.5rem;
        height: 1.5rem;
        object-fit: contain;
    }

    .footer-name {
        font-family: var(--font-heading);
        font-size: 0.9375rem;
        font-weight: 700;
        color: var(--deep);
    }

    .footer-sep {
        color: var(--border);
    }

    .footer-tagline {
        font-size: 0.8125rem;
        color: var(--muted-foreground);
    }

    .footer-links {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        gap: 0.25rem 1rem;
    }

    .footer-links a {
        font-size: 0.8125rem;
        color: var(--muted-foreground);
        text-decoration: none;
        transition: color 0.15s;
    }

    .footer-links a:hover { color: var(--deep); }

    .footer-github {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
    }
</style>