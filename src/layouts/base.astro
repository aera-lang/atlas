---
import '../styles/global.css'
import Nav from '../components/nav.astro'
import Footer from '../components/footer.astro'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'Aera — Where ideas take shape',
  description = 'Aera is a programming language designed to make coding feel right.',
} = Astro.props
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="color-scheme" content="light" />
        <meta name="theme-color" content="#fefcff" />
        <meta name="description" content={description} />
        <title>{title}</title>
        <link rel="icon" href="/favicon.ico" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
        href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
        rel="stylesheet"
        />
    </head>
    <body>
        <Nav />
        <slot />
        <Footer />
    </body>
</html>