---
import Base from '../layouts/base.astro'
import CodeBlock from '../components/code-block.astro'
import GitHubLink from '../components/github-link.astro'

const example = `# a simple example

variant Shape {
  Circle(r)
  Rectangle(w, h)
}

fn area(s) {
  match s {
    Circle(r) => 3.14 * (r * r)
    Rectangle(w, h) => w * h
  }
}`
---

<Base>
	<main>
		<section class="hero">
			<div class="hero-mascot">
				<img src="https://placehold.co/180x180" alt="Aera mascot" width="180" height="180" />
			</div>
			<h1>Aera</h1>
			<p class="hero-sub">
				Where ideas take shape. An expression-oriented programming language 
				centered around clarity and simplicity.
			</p>
			<div class="hero-actions">
				<a href="/atlas" class="btn-primary">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
					<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
				</svg>
				Read the Atlas
				</a>
				<GitHubLink href="https://github.com/aera-lang/aera" label="GitHub" class="btn-secondary" width={18} height={18}/>
			</div>
		</section>

		<section class="about">
			<div class="about-inner">
				<div class="about-left">
				<span class="eyebrow">The language</span>
				<h2>Built around one idea</h2>
				<p class="about-lead">
				Aera is an expression-oriented language with one goal: code should
					just feel right. No hidden state, no guessing. Clean syntax, immutable state, static typing.
					Everything made explicit.
				</p>
				<a href="/vision" class="about-link">
					Read the vision
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
					<path d="M5 12h14M12 5l7 7-7 7"/>
					</svg>
				</a>
				</div>
				<div class="feature-list">
				<div class="feature">
					<span class="feature-dot" style="background: var(--pink)"></span>
					<div>
					<strong>Expression-oriented</strong>
					<p>Everything is an expression. Code evaluates to values, including control flow.</p>
					</div>
				</div>
				<div class="feature">
					<span class="feature-dot" style="background: var(--blue)"></span>
					<div>
					<strong>Algebraic effects</strong>
					<p>Effects separate what your code does from how it's handled, and are resumable.</p>
					</div>
				</div>
				<div class="feature">
					<span class="feature-dot" style="background: var(--lavender)"></span>
					<div>
					<strong>Effect system</strong>
					<p>Side effects are tracked by the language and must be handled explicitly.</p>
					</div>
				</div>
				<div class="feature">
					<span class="feature-dot" style="background: var(--cream)"></span>
					<div>
					<strong>Transparent by design</strong>
					<p>Behaviour is visible, not hidden. What you see is what you get.</p>
					</div>
				</div>
				</div>
			</div>
		</section>

		<section class="example">
			<div class="example-inner">
				<div class="example-text">
				<span class="eyebrow">An example</span>
				<h2>Describe your data.<br />Let matching do the rest.</h2>
				<p>
					In Aera, a <code>variant</code> lets you model every possible value in a single type.
					Constructors let each possibility carry its own data.
					The <code>match</code> expression handles each case directly.
					This makes code easier to read, safer to write, and harder to get wrong.
				</p>
				</div>
				<CodeBlock code={example} label="shapes.aera" />
			</div>
		</section>

	</main>
</Base>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		min-height: calc(100vh - 4rem);
		padding: 5rem 1.25rem;
		text-align: center;
	}

	.hero-mascot img {
		width: 10rem;
		height: 10rem;
		object-fit: contain;
		margin-bottom: 2rem;
	}

	@media (min-width: 640px) {
		.hero-mascot img { width: 12rem; height: 12rem; }
	}

	.hero h1 {
		margin: 0;
		font-family: var(--font-heading);
		font-size: clamp(3.5rem, 10vw, 5rem);
		font-weight: 700;
		letter-spacing: -0.03em;
		color: var(--deep);
		line-height: 1;
	}

	.hero-sub {
		margin: 1.25rem auto 0;
		max-width: 36rem;
		font-size: clamp(1rem, 2.5vw, 1.125rem);
		line-height: 1.7;
		color: var(--muted-foreground);
		text-wrap: balance;
	}

	.hero-actions {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.75rem;
		margin-top: 2.25rem;
	}

	@media (min-width: 640px) {
		.hero-actions { flex-direction: row; }
	}

	.btn-primary {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		border-radius: 9999px;
		background: var(--deep);
		padding: 0.75rem 1.5rem;
		font-size: 1rem;
		font-weight: 500;
		color: var(--background);
		text-decoration: none;
		transition: opacity 0.15s;
	}

	.btn-primary:hover { opacity: 0.85; }

	.btn-secondary {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		border-radius: 9999px;
		border: 1px solid color-mix(in srgb, var(--deep) 15%, transparent);
		background: color-mix(in srgb, var(--background) 40%, transparent);
		backdrop-filter: blur(8px);
		padding: 0.75rem 1.5rem;
		font-size: 1rem;
		font-weight: 500;
		color: var(--deep);
		text-decoration: none;
		transition: background-color 0.15s;
	}

	.btn-secondary:hover {
		background: color-mix(in srgb, var(--background) 60%, transparent);
	}

	.about {
		border-top: 1px solid var(--border);
		background: var(--mist);
		padding: 5rem 1.25rem;
	}

	.about-inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		max-width: 72rem;
		margin-inline: auto;
		align-items: start;
	}

	@media (max-width: 768px) {
		.about-inner { grid-template-columns: 1fr; gap: 2.5rem; }
	}

	.about-left h2 {
		margin: 0.25rem 0 1rem;
		font-family: var(--font-heading);
		font-size: clamp(1.5rem, 4vw, 2rem);
		font-weight: 700;
		color: var(--deep);
		letter-spacing: -0.02em;
	}

	.about-lead {
		margin: 0 0 1.5rem;
		line-height: 1.75;
		color: var(--muted-foreground);
	}

	.about-link {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		font-size: 0.9375rem;
		font-weight: 500;
		color: var(--primary);
		text-decoration: none;
		transition: gap 0.15s;
	}

	.about-link:hover { gap: 0.625rem; }

	.feature-list {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		padding-top: 0.25rem;
	}

	.feature {
		display: flex;
		gap: 0.875rem;
		align-items: flex-start;
	}

	.feature-dot {
		flex-shrink: 0;
		width: 0.625rem;
		height: 0.625rem;
		border-radius: 9999px;
		margin-top: 0.4rem;
	}

	.feature strong {
		display: block;
		font-size: 0.9375rem;
		font-weight: 600;
		color: var(--deep);
		margin-bottom: 0.25rem;
	}

	.feature p {
		margin: 0;
		font-size: 0.875rem;
		line-height: 1.6;
		color: var(--muted-foreground);
	}

	.example {
		border-top: 1px solid var(--border);
		background: var(--background);
		padding: 5rem 1.25rem;
	}

	.example-inner {
		display: grid;
		gap: 3rem;
		max-width: 72rem;
		margin-inline: auto;
	}

	@media (min-width: 768px) {
		.example-inner {
		grid-template-columns: 1fr 1fr;
		align-items: center;
		}
	}

	.example-text h2 {
		margin: 0.25rem 0 1rem;
		font-family: var(--font-heading);
		font-size: clamp(1.5rem, 4vw, 2rem);
		font-weight: 700;
		color: var(--deep);
		letter-spacing: -0.02em;
		line-height: 1.25;
	}

	.example-text p {
		margin: 0;
		line-height: 1.75;
		color: var(--muted-foreground);
	}

	.example-text code {
		font-family: var(--font-mono);
		font-size: 0.875em;
		background: color-mix(in srgb, var(--accent) 70%, transparent);
		padding: 0.1em 0.35em;
		border-radius: 0.25rem;
		color: var(--deep);
	}

	.eyebrow {
		display: inline-block;
		margin-bottom: 0.5rem;
		font-size: 0.8125rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--primary);
	}
</style>